{
  "expo": {
    "name": "Top Spin Titans",
    "slug": "movil",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon.png",
    "scheme": "topspintitans",
    "userInterfaceStyle": "automatic",
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/app-icon.png",
        "backgroundColor": "#212227"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.topspintitans.app",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "headers": {
            "Cross-Origin-Embedder-Policy": "credentialless",
            "Cross-Origin-Opener-Policy": "same-origin"
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#212227",
          "image": "./assets/images/app-icon.png",
          "imageWidth": 200,
          "android": {
            "backgroundColor": "#212227",
            "image": "./assets/images/app-icon.png",
            "imageWidth": 200
          }
        }
      ],
      "expo-sqlite",
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "La app usa tus fotos para que elijas tu foto de perfil."
        }
      ],
      "expo-sharing",
      [
        "react-native-share",
        {
          "ios": [
            "instagram",
            "instagram-stories"
          ],
          "android": [
            "com.instagram.android"
          ]
        }
      ],
      "expo-build-properties"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {
        "headers": {
          "Cross-Origin-Embedder-Policy": "credentialless",
          "Cross-Origin-Opener-Policy": "same-origin"
        }
      },
      "eas": {
        "projectId": "bc633d80-820f-4c5e-beb3-5e7385d7193a"
      }
    }
  }
}
