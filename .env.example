# Copiar a .env y completar con los valores del proyecto Supabase
# (Project Settings -> API en el panel de Supabase).
EXPO_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# Facebook App ID. Meta lo exige (desde ene-2023) para publicar en Instagram
# Stories. Se crea gratis en https://developers.facebook.com/apps (tipo
# "Consumer"); copiar el "App ID" del panel. Sin esto, el compartir tipo sticker
# cae al menu normal de compartir como respaldo.
EXPO_PUBLIC_FB_APP_ID=tu-facebook-app-id
